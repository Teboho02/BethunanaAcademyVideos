{
  "name": "bethunana-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-api-worker.mjs dev",
    "dev:api": "tsx watch src/index.tsx",
    "dev:worker": "tsx watch src/workers/mediaJobs.worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node scripts/run-api-worker.mjs start",
    "start:api": "node dist/index.js",
    "start:worker": "node dist/workers/mediaJobs.worker.js",
    "worker": "node dist/workers/mediaJobs.worker.js",
    "seed:grade10-subjects": "tsx src/scripts/seedGrade10Subjects.ts",
    "seed:grade10-topics": "tsx src/scripts/seedGrade10Topics.ts",
    "seed:grade11-topics": "tsx src/scripts/seedGrade11Topics.ts",
    "seed:grade12-topics": "tsx src/scripts/seedGrade12Topics.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.744.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.5",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
